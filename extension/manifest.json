{
  "manifest_version": 3,
  "name": "CRAAP Checker",
  "version": "2.0.0",
  "description": "AI-powered source credibility analyzer based on the academic CRAAP test.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
